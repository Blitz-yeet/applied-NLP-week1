    "\n",
    "# Normalize for tokenization\n",
    "wonderland   = normalize(wonderland_raw)\n",
    "lookingglass = normalize(lookingglass_raw)\n",
    "pet   = normalize(pet_raw)\n",
    "shining = normalize(shining_raw)\n",
